{
  "extension": [".ts"],
  "include": ["src/**/*.ts"],
  "exclude": ["test/**/*.ts"],
  "require": ["ts-node/esm"],
  "loader": "ts-node/esm",
  "sourceMap": true,
  "instrument": true,
  "check-coverage": true,
  "lines": 75,
  "statements": 75,
  "functions": 75,
  "branches": 75,
  "all": true
}
